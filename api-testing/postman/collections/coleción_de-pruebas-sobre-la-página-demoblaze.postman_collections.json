            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"mensaje de error cuando el usuario esta duplicado\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.errorMessage) {",
                  "        pm.expect(jsonData.errorMessage).to.eql(\"This user already exist.\");",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"respuesta es json\", function(){",
                  "pm.response.to.be.json;",
                  "})",
                  "",
                  "pm.test(\"Tiempo de respuesta aceptable\", function () {",
                  "pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test(\"La respuesta no está vacía\", function () {",
                  "pm.expect(pm.response.text().length).to.be.above(0);",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
